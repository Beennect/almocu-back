# JWT Secret - MUST be changed in production (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-secret

# Internal API key for service-to-service communication
INTERNAL_API_KEY=change-me-to-a-random-key

# MongoDB
MONGODB_URI=mongodb://localhost:27017/almocu

# Redis
REDIS_URI=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Microservice URLs (for the auth gateway proxy)
# Em produção (Docker), usa os nomes dos serviços (ex: http://stock-app:3000)
# Em desenvolvimento local, aponta para as portas locais:
STOCK_SERVICE_URL=http://localhost:3100
MENU_SERVICE_URL=http://localhost:3200
ORDER_SERVICE_URL=http://localhost:3300

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key

STRIPE_SUCCESS_URL=http://localhost:8081/payment/success
STRIPE_CANCEL_URL=http://localhost:8081/payment/cancel