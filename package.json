{
  "name": "almoco-monorepo",
  "version": "1.0.0",
  "description": "Almoco ERP — NestJS Monorepo (auth, menu, stock, order)",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build -p tsconfig.build.json",
    "build:auth": "nest build auth -p tsconfig.build.json",
    "build:menu": "nest build menu -p tsconfig.build.json",
    "build:stock": "nest build stock -p tsconfig.build.json",
    "build:order": "nest build order -p tsconfig.build.json",
    "build:all": "nest build auth -p tsconfig.build.json && nest build menu -p tsconfig.build.json && nest build stock -p tsconfig.build.json && nest build order -p tsconfig.build.json",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:auth": "nest start auth",
    "start:menu": "nest start menu",
    "start:stock": "nest start stock",
    "start:order": "nest start order",
    "start:dev": "nest start --watch",
    "start:dev:auth": "nest start auth --watch",
    "start:dev:menu": "nest start menu --watch",
    "start:dev:stock": "nest start stock --watch",
    "start:dev:order": "nest start order --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod:auth": "node dist/apps/auth/main",
    "start:prod:menu": "node dist/apps/menu/main",
    "start:prod:stock": "node dist/apps/stock/main",
    "start:prod:order": "node dist/apps/order/main",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "test:auth": "bun test apps/auth/src/",
    "test:menu": "bun test apps/menu/src/",
    "test:stock": "bun test apps/stock/src/",
    "test:order": "bun test apps/order/src/",
    "test:e2e": "bun test ./apps/*/test/*.e2e-spec.ts",
    "test:auth:e2e": "bun test ./apps/auth/test/auth.e2e-spec.ts",
    "test:menu:e2e": "bun test ./apps/menu/test/menu.e2e-spec.ts",
    "test:order:e2e": "bun test ./apps/order/test/order.e2e-spec.ts",
    "test:stock:e2e": "bun test ./apps/stock/test/stock.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.24",
    "axios": "^1.15.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "fast-xml-parser": "^5.8.0",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.10.1",
    "jwks-rsa": "^4.0.1",
    "mongoose": "^8.9.0",
    "openid-client": "^6.8.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^14.0.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}